---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];

  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
};

const { tag, posts } = Astro.props;
---

<Base title={`#${tag} — OpsNotes`} description={`Статьи по теме ${tag}`}>
  <div class="container" style="padding-top:3rem;padding-bottom:4rem;position:relative;z-index:1;">
    <a href="/" style="font-family:var(--mono);font-size:0.78rem;color:var(--muted);display:inline-block;margin-bottom:2rem;transition:color 0.2s;">← Все статьи</a>

    <div style="margin-bottom:2.5rem;">
      <div style="font-family:var(--mono);font-size:0.7rem;color:var(--muted);margin-bottom:0.75rem;text-transform:uppercase;letter-spacing:0.1em;">// Тег</div>
      <h1 style="font-family:var(--serif);font-size:2.5rem;font-weight:300;color:#e8f0ec;">#{tag}</h1>
      <p style="font-family:var(--mono);font-size:0.8rem;color:var(--muted);margin-top:0.5rem;">{posts.length} статей</p>
    </div>

    <div style="max-width:780px;">
      {posts.map((post, i) => (
        <PostCard post={post} index={i} />
      ))}
    </div>
  </div>
</Base>
