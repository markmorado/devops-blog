---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];

const CATEGORY_LABELS: Record<string, string> = {
  'ci-cd':          'CI/CD',
  'virtualization': 'Виртуализация',
  'infrastructure': 'Инфраструктура',
};

// Категории с количеством статей
const catMap = new Map<string, number>();
for (const post of posts) {
  const cat = post.data.category;
  if (cat) catMap.set(cat, (catMap.get(cat) ?? 0) + 1);
}
const categories = [...catMap.entries()].sort((a, b) => b[1] - a[1]);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'TZIM Blog',
  description: 'DevOps: Docker, Proxmox, CI/CD',
  url: Astro.site?.toString(),
  inLanguage: 'ru',
  author: {
    '@type': 'Person',
    name: 'TZIM',
    url: Astro.site?.toString(),
  },
  blogPost: posts.map(post => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.excerpt,
    datePublished: post.data.date.toISOString(),
    url: new URL(`/posts/${post.slug}/`, Astro.site).toString(),
  })),
};
---

<Base title="TZIM Blog">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <div class="container page">

    <section class="hero">
      <h1>Заметки об инфраструктуре</h1>
      <p class="hero-desc">
        Docker, Proxmox, DNS, CI/CD — реальные решения без воды.
      </p>
    </section>

    <div class="layout">
      <div class="posts">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>

      <aside>
        <div class="aside-section">
          <h2>Категории</h2>
          <ul class="cat-list">
            {categories.map(([slug, count]) => (
              <li>
                <a href={`/categories/${slug}`} class="cat-item">
                  <span class="cat-name">{CATEGORY_LABELS[slug] ?? slug}</span>
                  <span class="cat-count">{count}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="aside-section">
          <h2>Теги</h2>
          <div class="tag-list">
            {allTags.map(tag => (
              <a href={`/tags/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        </div>

        <div class="aside-section">
          <h2>Подписка</h2>
          <p><a href="/rss.xml">RSS Feed</a></p>
          <p><a href="https://t.me/yourchannel">Telegram</a></p>
        </div>
      </aside>
    </div>

  </div>
</Base>

<style>
  .page {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .hero {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .hero-desc {
    color: var(--muted);
    font-size: 1rem;
    max-width: 480px;
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 4rem;
    align-items: start;
  }

  aside {
    position: sticky;
    top: 2rem;
  }

  .aside-section {
    margin-bottom: 2.5rem;
  }

  .aside-section h2 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  .aside-section p {
    font-size: 0.9rem;
    line-height: 2;
  }

  .aside-section p a {
    color: var(--muted);
    text-decoration: none;
  }

  .aside-section p a:hover { color: var(--text); }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
  }

  .tag-list .tag {
    font-size: 0.8rem;
    font-family: var(--mono);
    color: var(--muted);
    text-decoration: none;
  }

  .tag-list .tag:hover { color: var(--text); }

  /* Категории в сайдбаре */
  .cat-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }

  .cat-list li:first-child .cat-item { border-top: 1px solid var(--border); }

  .cat-name {
    font-size: 0.85rem;
    color: var(--text);
  }

  .cat-item:hover .cat-name { color: var(--muted); }

  .cat-count {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  @media (max-width: 700px) {
    .layout { grid-template-columns: 1fr; }
    aside { position: static; }
  }
</style>
