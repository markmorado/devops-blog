---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))];
---

<Base title="TZIM Blog">
  <div class="container page">

    <section class="hero">
      <h1>Заметки об инфраструктуре</h1>
      <p class="hero-desc">
        Docker, Proxmox, DNS, CI/CD — реальные решения без воды.
      </p>
    </section>

    <div class="layout">
      <div class="posts">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>

      <aside>
        <div class="aside-section">
          <h2>Теги</h2>
          <div class="tag-list">
            {allTags.map(tag => (
              <a href={`/tags/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        </div>

        <div class="aside-section">
          <h2>Подписка</h2>
          <p><a href="/rss.xml">RSS Feed</a></p>
          <p><a href="https://t.me/yourchannel">Telegram</a></p>
        </div>
      </aside>
    </div>

  </div>
</Base>

<style>
  .page {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .hero {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .hero-desc {
    color: var(--muted);
    font-size: 1rem;
    max-width: 480px;
  }

  .layout {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 4rem;
    align-items: start;
  }

  aside {
    position: sticky;
    top: 2rem;
  }

  .aside-section {
    margin-bottom: 2.5rem;
  }

  .aside-section h2 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  .aside-section p {
    font-size: 0.9rem;
    line-height: 2;
  }

  .aside-section p a {
    color: var(--muted);
    text-decoration: none;
  }

  .aside-section p a:hover { color: var(--text); }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
  }

  .tag-list .tag {
    font-size: 0.8rem;
    font-family: var(--mono);
    color: var(--muted);
    text-decoration: none;
  }

  .tag-list .tag:hover { color: var(--text); }

  @media (max-width: 700px) {
    .layout { grid-template-columns: 1fr; }
    aside { position: static; }
  }
</style>
