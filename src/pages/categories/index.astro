---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const CATEGORY_LABELS: Record<string, string> = {
  'ci-cd':          'CI/CD',
  'virtualization': 'Виртуализация',
  'infrastructure': 'Инфраструктура',
};

const posts = await getCollection('posts', ({ data }) => !data.draft);

// Собираем категории с количеством статей
const catMap = new Map<string, number>();
for (const post of posts) {
  const cat = post.data.category;
  if (cat) catMap.set(cat, (catMap.get(cat) ?? 0) + 1);
}

const categories = [...catMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Категории — TZIM Blog" description="Все категории блога TZIM Blog">
  <div class="container page">
    <h1>Категории</h1>
    <p class="subtitle">{categories.length} категории · {posts.length} статей</p>

    <div class="cat-list">
      {categories.map(([slug, count]) => (
        <a href={`/categories/${slug}`} class="cat-item">
          <div>
            <span class="cat-name">{CATEGORY_LABELS[slug] ?? slug}</span>
            <span class="cat-slug">/{slug}</span>
          </div>
          <span class="cat-count">{count} {count === 1 ? 'статья' : 'статей'}</span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .page {
    padding-top: 3rem;
    padding-bottom: 4rem;
    max-width: 720px;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .subtitle {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 3rem;
  }

  .cat-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cat-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }

  .cat-item:first-child { border-top: 1px solid var(--border); }
  .cat-item:hover .cat-name { color: var(--muted); }

  .cat-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    display: block;
    margin-bottom: 0.2rem;
  }

  .cat-slug {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .cat-count {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
  }
</style>
