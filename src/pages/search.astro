---
import Base from '../layouts/Base.astro';
---

<Base title="Qidiruv — TZIM Blog" description="TZIM Blog maqolalari bo'yicha qidiruv">
  <div class="container page">
    <h1>Qidiruv</h1>
    <div id="search"></div>
  </div>
</Base>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

<script is:inline>
  // Pagefind создаётся после сборки (postbuild), поэтому загружаем динамически
  (async () => {
    try {
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
      new PagefindUI({
        element: '#search',
        showImages: false,
        resetStyles: false,
        translations: {
          placeholder: 'Maqolalar bo\'yicha qidirish...',
          zero_results: '"[SEARCH_TERM]" bo\'yicha hech narsa topilmadi',
          many_results: '"[SEARCH_TERM]" bo\'yicha [COUNT] ta natija',
          one_result: '"[SEARCH_TERM]" bo\'yicha [COUNT] ta natija',
          alt_search: '"[SEARCH_TERM]" bo\'yicha natija yo\'q. "[DIFFERENT_TERM]" ni sinab ko\'raylikmi?',
          search_suggestion: '"[SEARCH_TERM]" bo\'yicha natija yo\'q. "[DIFFERENT_TERM]" bo\'yicha natijalar ko\'rsatilmoqda',
          searching: '"[SEARCH_TERM]" qidirilmoqda...',
        },
      });
    } catch {
      const el = document.getElementById('search');
      if (el) el.innerHTML = '<p class="search-unavailable">Qidiruv faqat <code>npm run build</code> dan keyin mavjud.</p>';
    }
  })();
</script>

<style is:global>
  /* Адаптация Pagefind UI под текущую тему */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--text);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--code-bg);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 3px;
    --pagefind-ui-font: var(--font);
  }
</style>

<style>
  .page {
    padding-top: 3rem;
    padding-bottom: 4rem;
    max-width: 720px;
  }

  h1 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
  }

  .search-unavailable {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  .search-unavailable code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--code-bg);
    padding: 2px 5px;
    border-radius: 3px;
  }
</style>
