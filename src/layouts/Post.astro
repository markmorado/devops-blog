---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, tags, readTime, excerpt, ogImage } = post.data;

const formattedDate = new Intl.DateTimeFormat('ru-RU', {
  year: 'numeric', month: 'long', day: 'numeric'
}).format(date);

const isoDate = date.toISOString();
const postUrl = new URL(`/posts/${post.slug}/`, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  datePublished: isoDate,
  dateModified: isoDate,
  url: postUrl,
  inLanguage: 'ru',
  author: {
    '@type': 'Person',
    name: 'TZIM',
    url: Astro.site?.toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: 'TZIM Blog',
    url: Astro.site?.toString(),
  },
  keywords: tags.join(', '),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postUrl,
  },
};
---

<Base title={`${title} — TZIM Blog`} description={excerpt} ogImage={ogImage} ogType="article">
  <Fragment slot="head">
    <meta property="article:published_time" content={isoDate} />
    <meta property="article:author" content="TZIM" />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <article class="container page">

    <a href="/" class="back">← Все статьи</a>

    <header>
      <div class="meta">
        <time>{formattedDate}</time>
        <span>·</span>
        <span>{readTime} мин чтения</span>
      </div>
      <h1>{title}</h1>
      <p class="excerpt">{excerpt}</p>
      <div class="tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    </header>

    <hr />

    <div class="prose">
      <slot />
    </div>

    <hr />

    <div class="post-footer">
      <a href="/" class="back">← Все статьи</a>
      <div class="tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    </div>

  </article>
</Base>

<style>
  .page {
    max-width: 720px;
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2.5rem;
  }

  .back:hover { color: var(--text); }

  header { margin-bottom: 2.5rem; }

  .meta {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: var(--mono);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .excerpt {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    text-decoration: none;
  }

  .tag:hover { color: var(--text); }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
</style>
