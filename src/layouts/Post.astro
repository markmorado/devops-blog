---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, tags, readTime, excerpt } = post.data;

const formattedDate = new Intl.DateTimeFormat('ru-RU', {
  year: 'numeric', month: 'long', day: 'numeric'
}).format(date);
---

<Base title={`${title} — OpsNotes`} description={excerpt}>
  <article class="container" style="padding-top:4rem;padding-bottom:4rem;">

    <!-- Back link -->
    <a href="/" class="back-link">← Все статьи</a>

    <!-- Header -->
    <header class="post-header">
      <div class="post-meta">
        <time style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);">{formattedDate}</time>
        <span style="color:var(--border);">·</span>
        <span style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);">{readTime} мин чтения</span>
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-excerpt">{excerpt}</p>

      <div class="tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>

      <div class="divider"></div>
    </header>

    <!-- Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Footer nav -->
    <div class="divider" style="margin-top:3rem;"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2rem;">
      <a href="/" class="back-link">← Все статьи</a>
      <div class="tags">
        {tags.map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    </div>

  </article>
</Base>

<style>
  .back-link {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--muted);
    transition: color 0.2s;
    display: inline-block;
    margin-bottom: 2rem;
  }
  .back-link:hover { color: var(--accent); text-decoration: none; }

  .post-header { margin-bottom: 2.5rem; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .post-title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 600;
    color: #e8f0ec;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .post-excerpt {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags a:hover { text-decoration: none; opacity: 0.8; }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 2rem 0;
  }
</style>
