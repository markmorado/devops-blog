---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description = 'TZIM Blog — DevOps: Docker, Proxmox, CI/CD', ogImage, ogType = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <meta name="author" content="TZIM" />
  <meta name="theme-color" content="#0f0f0f" />

  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="TZIM Blog" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />}

  <link rel="alternate" type="application/rss+xml" title="TZIM Blog RSS" href="/rss.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <slot name="head" />

  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    const saved = localStorage.getItem('theme');
    document.documentElement.dataset.theme = saved ?? 'dark';
  </script>
</head>
<body>

  <header>
    <div class="container">
      <nav>
        <a href="/" class="site-name">TZIM Blog</a>
        <div class="nav-right">
          <ul>
            <li><a href="/">Maqolalar</a></li>
            <li><a href="/tags">Teglar</a></li>
            <li><a href="/about">Men haqimda</a></li>
            <li><a href="/rss.xml">RSS</a></li>
          </ul>
          <a href="/search" class="search-btn" aria-label="Qidiruv">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Mavzuni almashtirish">
            <!-- Sun: shown in dark mode -->
            <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <!-- Moon: shown in light mode -->
            <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </nav>
    </div>
  </header>

  <main data-pagefind-body>
    <slot />
  </main>

  <footer>
    <div class="container">
      <span>© {new Date().getFullYear()} TZIM Blog</span>
      <div class="footer-links">
        <a href="https://github.com/yourname">GitHub</a>
        <a href="https://t.me/yourchannel">Telegram</a>
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name {
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    color: var(--text);
  }

  ul {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  ul a {
    font-size: 0.9rem;
    color: var(--muted);
    text-decoration: none;
  }

  ul a:hover { color: var(--text); }

  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 6rem;
  }

  footer .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .footer-links a:hover { color: var(--text); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .search-btn {
    display: flex;
    align-items: center;
    color: var(--muted);
    text-decoration: none;
    padding: 4px;
  }

  .search-btn:hover { color: var(--text); }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    padding: 4px;
    display: flex;
    align-items: center;
    line-height: 1;
  }

  .theme-toggle:hover { color: var(--text); }

  /* Dark (default): show sun to switch to light */
  .icon-moon { display: none; }
  /* Light mode: show moon to switch to dark */
  :root[data-theme="light"] .icon-sun { display: none; }
  :root[data-theme="light"] .icon-moon { display: block; }

  @media (max-width: 600px) {
    ul { gap: 1.25rem; }
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const current = document.documentElement.dataset.theme ?? 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
