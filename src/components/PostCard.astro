---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  index?: number;
  featured?: boolean;
}

const CATEGORY_LABELS: Record<string, string> = {
  'ci-cd':          'CI/CD',
  'virtualization': 'Виртуализация',
  'infrastructure': 'Инфраструктура',
};

const { post } = Astro.props;
const { title, date, tags, readTime, excerpt, category } = post.data;

const formattedDate = new Intl.DateTimeFormat('ru-RU', {
  year: 'numeric', month: 'short', day: 'numeric'
}).format(date);
---

<article class="post-item">
  <div class="post-meta">
    <time>{formattedDate}</time>
    <span>·</span>
    <span>{readTime} мин</span>
    {category && (
      <>
        <span>·</span>
        <a href={`/categories/${category}`} class="cat-link">{CATEGORY_LABELS[category] ?? category}</a>
      </>
    )}
  </div>
  <h2><a href={`/posts/${post.slug}`}>{title}</a></h2>
  <p class="excerpt">{excerpt}</p>
  <div class="tags">
    {tags.slice(0, 3).map(tag => (
      <a href={`/tags/${tag}`} class="tag">{tag}</a>
    ))}
  </div>
</article>

<style>
  .post-item {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
  }

  h2 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  h2 a { text-decoration: none; color: var(--text); }
  h2 a:hover { color: var(--muted); }

  .excerpt {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
  }

  .tag {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
  }

  .tag:hover { color: var(--text); }

  .cat-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
  }

  .cat-link:hover { color: var(--text); }
</style>
