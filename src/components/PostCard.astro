---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  index?: number;
  featured?: boolean;
}

const { post, index = 0, featured = false } = Astro.props;
const { title, date, tags, readTime, excerpt } = post.data;

const formattedDate = new Intl.DateTimeFormat('ru-RU', {
  year: 'numeric', month: 'short', day: 'numeric'
}).format(date);
---

{featured ? (
  <article class="card featured">
    <div class="featured-bar"></div>
    <div class="card-body">
      <div class="card-meta">
        <time>{formattedDate}</time>
        {tags.slice(0, 2).map(tag => (
          <a href={`/tags/${tag}`} class="tag">{tag}</a>
        ))}
        <span class="featured-badge">FEATURED</span>
      </div>
      <h2 class="card-title"><a href={`/posts/${post.slug}`}>{title}</a></h2>
      <p class="card-excerpt">{excerpt}</p>
      <div class="card-footer">
        <a href={`/posts/${post.slug}`} class="read-more">Читать статью →</a>
        <span class="read-time">{readTime} мин</span>
      </div>
    </div>
  </article>
) : (
  <article class="card list-card">
    <div class="list-card-inner">
      <div>
        <div class="card-meta">
          <time>{formattedDate}</time>
          {tags.slice(0, 2).map(tag => (
            <a href={`/tags/${tag}`} class="tag">{tag}</a>
          ))}
          <span class="read-time">{readTime} мин</span>
        </div>
        <h2 class="list-title"><a href={`/posts/${post.slug}`}>{title}</a></h2>
      </div>
      <div class="list-num">
        {String(index + 1).padStart(2, '0')}
      </div>
    </div>
  </article>
)}

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.25s;
  }
  .card:hover { border-color: var(--accent); }

  /* Featured */
  .featured { margin-bottom: 1.5rem; position: relative; }
  .featured-bar { height: 3px; background: linear-gradient(90deg, var(--accent), transparent); }
  .card-body { padding: 2rem; }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .card-meta time {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  .featured-badge {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 2px 6px;
    letter-spacing: 0.1em;
    margin-left: auto;
  }

  .card-title {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .card-title a { color: #e8f0ec; }
  .card-title a:hover { color: var(--accent); text-decoration: none; }

  .card-excerpt {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .read-more {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    transition: letter-spacing 0.2s;
  }

  .read-more:hover { letter-spacing: 0.03em; text-decoration: none; }

  .read-time {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted);
  }

  /* List card */
  .list-card { margin-bottom: 1px; border-radius: 2px; }
  .list-card-inner {
    padding: 1.25rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
  }

  .list-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    margin-top: 0.4rem;
    line-height: 1.3;
  }

  .list-title a { color: #c8d8d2; }
  .list-title a:hover { color: var(--accent); text-decoration: none; }

  .list-num {
    font-family: var(--mono);
    font-size: 1.8rem;
    color: var(--border);
    font-weight: 700;
    user-select: none;
  }

  /* Tags */
  .tag {
    font-family: var(--mono);
    font-size: 0.62rem;
    padding: 2px 7px;
    border-radius: 2px;
    background: rgba(0,229,160,0.08);
    color: var(--accent);
    border: 1px solid rgba(0,229,160,0.18);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 0.2s;
  }

  .tag:hover { background: rgba(0,229,160,0.15); text-decoration: none; }
</style>
